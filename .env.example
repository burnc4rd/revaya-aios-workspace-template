# ============================================================
# Your AIOS Workspace — Environment Configuration
# ============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains your secrets.
# The .gitignore file already prevents this, but be careful.
# ============================================================

# --- IntelOS (meeting + Slack collection) ---
FIREFLIES_API_KEY=your-fireflies-api-key-here
SLACK_TOKEN_MAIN=xoxb-your-slack-bot-token-here

# --- CommandOS (Telegram AI assistant) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_GROUP_ID=-100your-group-id-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# --- CommandOS Tuning (optional — defaults are fine) ---
# COMMAND_GENERAL_MODEL=sonnet
# COMMAND_GENERAL_MAX_TURNS=30
# COMMAND_GENERAL_MAX_BUDGET=5.00
# COMMAND_CONTEXT_WARNING_TOKENS=180000

# --- Content Engine (Airtable) ---
AIRTABLE_TOKEN=your-airtable-personal-access-token-here
# Scopes needed: data.records:read, data.records:write, schema.bases:read, schema.bases:write
# Get token at: https://airtable.com/create/tokens

# --- Future modules will add keys below ---
# GEMINI_API_KEY=AI...
